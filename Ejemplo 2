const fileToBase64 = file => new Promise((res, rej) => {
  const r = new FileReader();
  r.onload = () => res(r.result);
  r.onerror = rej;
  r.readAsDataURL(file);
});

function LogoJ10({ size = 40, color = "#1d1d1f" }) {
  return (
    <svg width={size} height={size} viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M100 8 A92 92 0 0 0 8 100" stroke={color} strokeWidth="18" strokeLinecap="round" fill="none"/>
      <path d="M8 100 A92 92 0 0 0 100 192" stroke={color} strokeWidth="18" strokeLinecap="round" fill="none"/>
      <path d="M100 192 A92 92 0 0 0 175 152" stroke={color} strokeWidth="18" strokeLinecap="round" fill="none"/>
      <path d="M155 34 A92 92 0 0 1 192 100" stroke={color} strokeWidth="18" strokeLinecap="round" fill="none"/>
      <rect x="52" y="62" width="18" height="72" rx="2" fill={color}/>
      <path d="M52 126 Q52 142 38 142 Q30 142 26 136" stroke={color} strokeWidth="14" strokeLinecap="round" fill="none"/>
      <rect x="82" y="54" width="16" height="84" rx="2" fill={color}/>
      <path d="M82 62 L72 72" stroke={color} strokeWidth="10" strokeLinecap="round"/>
      <rect x="108" y="54" width="52" height="84" rx="26" fill={color}/>
      <rect x="122" y="68" width="24" height="56" rx="12" fill="white"/>
    </svg>
  );
}

function ImagePicker({ value, onChange }) {
  const fileRef = useRef();
  const [urlInput, setUrlInput] = useState("");
  const [tab, setTab] = useState("upload");
  const handleFile = async e => { const f = e.target.files[0]; if (f) onChange(await fileToBase64(f)); };
  const handleUrl = () => { if (urlInput.trim()) { onChange(urlInput.trim()); setUrlInput(""); } };
  const inp = { width: "100%", padding: "10px 12px", borderRadius: 10, border: "1px solid #d1d1d6", fontSize: 13, outline: "none", color: "#1d1d1f", background: "#fff", boxSizing: "border-box" };
  return (
    <div>
      {value && <img src={value} alt="preview" style={{ width: "100%", height: 150, objectFit: "cover", borderRadius: 10, marginBottom: 10 }} onError={e => { e.target.style.display = "none"; }} />}
      <div style={{ display: "flex", marginBottom: 10, borderRadius: 10, overflow: "hidden", border: "1px solid #d1d1d6" }}>
        {["upload","url"].map(t => (
          <button key={t} onClick={() => setTab(t)} style={{ flex: 1, padding: "8px 0", background: tab === t ? "#1d1d1f" : "#fff", color: tab === t ? "#fff" : "#555", border: "none", cursor: "pointer", fontWeight: 500, fontSize: 13 }}>
            {t === "upload" ? "📁 Subir archivo" : "🔗 URL"}
          </button>
        ))}
      </div>
      {tab === "upload" && <>
        <div onClick={() => fileRef.current.click()} style={{ border: "1.5px dashed #d1d1d6", borderRadius: 12, padding: "20px 16px", textAlign: "center", cursor: "pointer", background: "#f5f5f7" }}>
          <div style={{ fontSize: 24, marginBottom: 6 }}>📷</div>
          <div style={{ color: "#555", fontSize: 13 }}>Toca para seleccionar</div>
          <div style={{ color: "#aaa", fontSize: 11, marginTop: 3 }}>JPG, PNG, WEBP</div>
        </div>
        <input ref={fileRef} type="file" accept="image/*" style={{ display: "none" }} onChange={handleFile} />
      </>}
      {tab === "url" && (
        <div style={{ display: "flex", gap: 8 }}>
          <input style={{ ...inp, flex: 1 }} placeholder="https://..." value={urlInput} onChange={e => setUrlInput(e.target.value)} onKeyDown={e => { if (e.key === "Enter") handleUrl(); }} />
          <button onClick={handleUrl} style={{ padding: "10px 16px", borderRadius: 10, background: "#1d1d1f", color: "#fff", border: "none", fontWeight: 600, cursor: "pointer", fontSize: 13 }}>OK</button>
        </div>
      )}
    </div>
  );
}

function AdminSection({ label, children }) {
  return (
    <div style={{ marginBottom: 24 }}>
      <div style={{ fontSize: 11, fontWeight: 700, letterSpacing: 1, textTransform: "uppercase", color: "#6e6e73", marginBottom: 10, borderBottom: "1px solid #e5e5ea", paddingBottom: 8 }}>{label}</div>
      <div style={{ background: "#fff", border: "1px solid #e5e5ea", borderRadius: 16, padding: 20 }}>{children}</div>
    </div>
  );
}

export default function App() {
  const [products, setProducts] = useState(DEFAULT_PRODUCTS);
  const [categories, setCategories] = useState(DEFAULT_CATEGORIES);
  const [whatsapp, setWhatsapp] = useState("573001234567");
  const [adminPassword, setAdminPassword] = useState("admin123");
  const [logoImg, setLogoImg] = useState(null);
  const [bannerImg, setBannerImg] = useState(DEFAULT_BANNER);
  const [loaded, setLoaded] = useState(false);
  const [saving, setSaving] = useState(false);

  const [view, setView] = useState("client");
  const [activeCat, setActiveCat] = useState(null);
  const [search, setSearch] = useState("");
  const [selectedImg, setSelectedImg] = useState(null);
  const [editingProduct, setEditingProduct] = useState(null);
  const [loginPw, setLoginPw] = useState("");
  const [loginErr, setLoginErr] = useState(false);
  const [editingWa, setEditingWa] = useState(false);
  const [waInput, setWaInput] = useState("");
  const [newCatName, setNewCatName] = useState("");
  const [newCatIcon, setNewCatIcon] = useState("📦");
  const [showIconPicker, setShowIconPicker] = useState(false);
  const [uploadCat, setUploadCat] = useState("");
  const [uploadName, setUploadName] = useState("");
  const [uploadImg, setUploadImg] = useState("");
  const [changingPw, setChangingPw] = useState(false);
  const [newPw, setNewPw] = useState("");
  const [confirmPw, setConfirmPw] = useState("");
  const [pwError, setPwError] = useState("");
  const [editingBanner, setEditingBanner] = useState(false);

  const logoRef = useRef();

  useEffect(() => {
    (async () => {
      try {
        const [p, c, w, pw, lg, bn] = await Promise.all([
          window.storage.get("catalogo:products").catch(() => null),
          window.storage.get("catalogo:categories").catch(() => null),
          window.storage.get("catalogo:whatsapp").catch(() => null),
          window.storage.get("catalogo:password").catch(() => null),
          window.storage.get("catalogo:logo").catch(() => null),
          window.storage.get("catalogo:banner").catch(() => null),
        ]);
        if (p) setProducts(JSON.parse(p.value));
        if (c) setCategories(JSON.parse(c.value));
        if (w) setWhatsapp(w.value);
        if (pw) setAdminPassword(pw.value);
        if (lg) setLogoImg(lg.value);
        if (bn) setBannerImg(bn.value);
      } catch (_) {}
      setLoaded(true);
    })();
  }, []);

  const persist = async (pr, ca, wa, pw) => {
    setSaving(true);
    try {
      await Promise.all([
        window.storage.set("catalogo:products", JSON.stringify(pr)),
        window.storage.set("catalogo:categories", JSON.stringify(ca)),
        window.storage.set("catalogo:whatsapp", wa),
        window.storage.set("catalogo:password", pw),
      ]);
    } catch (_) {}
    setTimeout(() => setSaving(false), 1000);
  };

  const updP = fn => setProducts(p => { const n = fn(p); persist(n, categories, whatsapp, adminPassword); return n; });
  const updC = fn => setCategories(c => { const n = fn(c); persist(products, n, whatsapp, adminPassword); return n; });
  const updWa = v => { setWhatsapp(v); persist(products, categories, v, adminPassword); };
  const updPw = v => { setAdminPassword(v); persist(products, categories, whatsapp, v); };
  const updLogo = async v => { setLogoImg(v); try { await window.storage.set("catalogo:logo", v || ""); } catch (_) {} };
  const updBanner = async v => { setBannerImg(v); try { await window.storage.set("catalogo:banner", v); } catch (_) {} };

  const toggleProduct = id => updP(ps => ps.map(p => p.id === id ? { ...p, enabled: !p.enabled } : p));
  const deleteProduct = id => updP(ps => ps.filter(p => p.id !== id));
  const saveEdit = () => {
    if (!editingProduct || !editingProduct.name.trim() || !editingProduct.img) return;
    updP(ps => ps.map(p => p.id === editingProduct.id ? { ...p, ...editingProduct } : p));
    setEditingProduct(null);
  };
  const addProduct = () => {
    if (!uploadName.trim() || !uploadImg || !uploadCat) return;
    updP(ps => [...ps, { id: Date.now(), catId: parseInt(uploadCat), name: uploadName.trim(), img: uploadImg, enabled: true }]);
    setUploadName(""); setUploadImg(""); setUploadCat("");
  };
  const addCategory = () => {
    if (!newCatName.trim()) return;
    updC(cs => [...cs, { id: Date.now(), name: newCatName.trim(), icon: newCatIcon }]);
    setNewCatName(""); setNewCatIcon("📦"); setShowIconPicker(false);
  };
  const deleteCat = id => {
    updC(cs => cs.filter(c => c.id !== id));
    updP(ps => ps.filter(p => p.catId !== id));
    if (activeCat === id) setActiveCat(null);
  };
  const handleLogin = () => {
    if (loginPw === adminPassword) { setView("admin"); setLoginErr(false); setLoginPw(""); }
    else setLoginErr(true);
  };
  const savePassword = () => {
    if (newPw.length < 6) { setPwError("Mínimo 6 caracteres"); return; }
    if (newPw !== confirmPw) { setPwError("Las contraseñas no coinciden"); return; }
    updPw(newPw); setChangingPw(false); setNewPw(""); setConfirmPw(""); setPwError("");
  };

  const visibleProducts = useMemo(() => {
    let list = view === "admin" ? products : products.filter(p => p.enabled);
    if (activeCat) list = list.filter(p => p.catId === activeCat);
    if (search) list = list.filter(p => p.name.toLowerCase().includes(search.toLowerCase()));
    return list;
  }, [products, activeCat, search, view]);

  const clientCats = categories.filter(c => products.some(p => p.catId === c.id && p.enabled));

  const inp = { width: "100%", padding: "11px 14px", borderRadius: 10, border: "1px solid #d1d1d6", fontSize: 14, outline: "none", color: "#1d1d1f", background: "#fff", boxSizing: "border-box", marginBottom: 10 };
  const secBtn = { padding: "10px 20px", borderRadius: 10, background: "#1d1d1f", color: "#fff", border: "none", fontWeight: 600, cursor: "pointer", fontSize: 14 };
  const ghostBtn = { padding: "10px 20px", borderRadius: 10, background: "#f5f5f7", color: "#1d1d1f", border: "none", fontWeight: 500, cursor: "pointer", fontSize: 14 };

  if (!loaded) return (
    <div style={{ minHeight: "100vh", background: "#fff", display: "flex", alignItems: "center", justifyContent: "center", flexDirection: "column", gap: 16, fontFamily: "-apple-system, 'Segoe UI', sans-serif" }}>
      <LogoJ10 size={52} />
      <div style={{ color: "#aaa", fontSize: 14 }}>Cargando...</div>
    </div>
  );

  if (view === "login") return (
    <div style={{ minHeight: "100vh", background: "#f5f5f7", display: "flex", alignItems: "center", justifyContent: "center", fontFamily: "-apple-system, 'Segoe UI', sans-serif" }}>
      <div style={{ background: "#fff", borderRadius: 20, padding: "48px 40px", width: 340, maxWidth: "92vw", boxShadow: "0 4px 24px rgba(0,0,0,0.08)" }}>
        <div style={{ textAlign: "center", marginBottom: 32 }}>
          <div style={{ fontSize: 36, marginBottom: 8 }}>🔐</div>
          <div style={{ fontSize: 22, fontWeight: 700, color: "#1d1d1f" }}>Panel Admin</div>
        </div>
        <input type="password" placeholder="Contraseña" value={loginPw}
          onChange={e => setLoginPw(e.target.value)} onKeyDown={e => { if (e.key === "Enter") handleLogin(); }}
          style={{ ...inp, border: loginErr ? "1px solid #ff3b30" : "1px solid #d1d1d6", marginBottom: loginErr ? 6 : 16 }} />
        {loginErr && <div style={{ color: "#ff3b30", fontSize: 13, marginBottom: 12 }}>Contraseña incorrecta</div>}
        <button onClick={handleLogin} style={{ ...secBtn, width: "100%", padding: 14, borderRadius: 12, fontSize: 15 }}>Entrar</button>
        <button onClick={() => setView("client")} style={{ ...ghostBtn, width: "100%", padding: 13, marginTop: 10, borderRadius: 12 }}>← Volver al catálogo</button>
      </div>
    </div>
  );

  return (
    <div style={{ minHeight: "100vh", background: view === "admin" ? "#f5f5f7" : "#fff", fontFamily: "-apple-system, 'Segoe UI', sans-serif", color: "#1d1d1f", paddingBottom: 80 }}>

      {/* HEADER */}
      <div style={{ background: "rgba(255,255,255,0.9)", backdropFilter: "blur(20px)", WebkitBackdropFilter: "blur(20px)", borderBottom: "1px solid #e5e5ea", padding: "0 24px", display: "flex", alignItems: "center", justifyContent: "space-between", height: 56, position: "sticky", top: 0, zIndex: 100 }}>
        {view === "admin"
          ? <div style={{ fontSize: 17, fontWeight: 600 }}>Panel de administración</div>
          : <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
              {logoImg ? <img src={logoImg} alt="logo" style={{ width: 36, height: 36, objectFit: "contain", borderRadius: 6 }} /> : <LogoJ10 size={34} />}
              <div style={{ fontSize: 16, fontWeight: 700, letterSpacing: -0.3, whiteSpace: "nowrap" }}>Distribuciones J10</div>
            </div>}
        <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
          {saving && <span style={{ fontSize: 12, color: "#007aff" }}>Guardando...</span>}
          {view === "admin"
            ? <button onClick={() => setView("client")} style={{ ...ghostBtn, padding: "7px 14px", fontSize: 13, borderRadius: 8 }}>← Salir</button>
            : <button onClick={() => setView("login")} style={{ background: "none", border: "none", cursor: "pointer", fontSize: 14, fontWeight: 500, color: "#007aff" }}>Admin</button>}
        </div>
      </div>

      {/* CLIENT */}
      {view === "client" && <>
        {/* HERO BANNER */}
        <div style={{ position: "relative", height: 400, overflow: "hidden", background: "#1d1d1f" }}>
          {bannerImg && <img src={bannerImg} alt="banner" style={{ width: "100%", height: "100%", objectFit: "cover", opacity: 0.5, display: "block" }} />}
          <div style={{ position: "absolute", inset: 0, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", textAlign: "center", padding: 32 }}>
            <div style={{ fontSize: 13, fontWeight: 600, color: "rgba(255,255,255,0.7)", marginBottom: 12, letterSpacing: 2 }}>COLECCIÓN</div>
            <div style={{ fontSize: 52, fontWeight: 800, color: "#fff", letterSpacing: -2, lineHeight: 1.05, marginBottom: 14 }}>
              {activeCat ? categories.find(c => c.id === activeCat)?.name : "Bienvenidos"}
            </div>
            <div style={{ fontSize: 15, color: "rgba(255,255,255,0.7)", maxWidth: 380, lineHeight: 1.6 }}>
              Los mejores productos seleccionados para ti
            </div>
          </div>
        </div>

        {/* CATEGORY TABS */}
        <div style={{ borderBottom: "1px solid #e5e5ea" }}>
          <div style={{ display: "flex", justifyContent: "center", overflowX: "auto", maxWidth: 960, margin: "0 auto" }}>
            {[{ id: null, name: "Todos", icon: "" }, ...clientCats].map(c => {
              const active = c.id === null ? !activeCat : activeCat === c.id;
              return (
                <button key={c.id === null ? "all" : c.id} onClick={() => setActiveCat(c.id)}
                  style={{ padding: "15px 22px", background: "none", border: "none", borderBottom: active ? "2.5px solid #1d1d1f" : "2.5px solid transparent", color: active ? "#1d1d1f" : "#6e6e73", fontWeight: active ? 700 : 400, cursor: "pointer", fontSize: 14, whiteSpace: "nowrap", marginBottom: -1 }}>
                  {c.icon} {c.name}
                </button>
              );
            })}
          </div>
        </div>

        {/* SEARCH */}
        <div style={{ maxWidth: 960, margin: "28px auto 20px", padding: "0 24px" }}>
          <div style={{ position: "relative", maxWidth: 480 }}>
            <span style={{ position: "absolute", left: 14, top: "50%", transform: "translateY(-50%)", color: "#aaa" }}>🔍</span>
            <input style={{ ...inp, paddingLeft: 42, marginBottom: 0, fontSize: 14, background: "#f5f5f7", border: "1px solid transparent", borderRadius: 12 }} placeholder="Buscar productos..." value={search} onChange={e => setSearch(e.target.value)} />
          </div>
        </div>

        {/* GRID */}
        <div style={{ maxWidth: 960, margin: "0 auto", padding: "0 24px" }}>
          {visibleProducts.length > 0 && (
            <div style={{ fontSize: 12, color: "#6e6e73", marginBottom: 16, letterSpacing: 0.5 }}>
              {visibleProducts.length} producto{visibleProducts.length !== 1 ? "s" : ""}
            </div>
          )}
          <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(200px, 1fr))", gap: 20 }}>
            {visibleProducts.map(p => (
              <div key={p.id} onClick={() => setSelectedImg(p)}
                style={{ borderRadius: 18, overflow: "hidden", background: "#f5f5f7", cursor: "pointer", border: "1px solid #e5e5ea", transition: "transform .15s" }}
                onMouseEnter={e => { e.currentTarget.style.transform = "scale(1.02)"; }}
                onMouseLeave={e => { e.currentTarget.style.transform = "scale(1)"; }}>
                <div style={{ background: "#fff", padding: 14 }}>
                  <img src={p.img} alt={p.name} style={{ width: "100%", aspectRatio: "1/1", objectFit: "cover", borderRadius: 10, display: "block" }} />
