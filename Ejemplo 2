                <div style={{ padding: "10px 14px 14px" }}>
                  <div style={{ fontSize: 14, fontWeight: 600, color: "#1d1d1f", marginBottom: 3 }}>{p.name}</div>
                  <div style={{ fontSize: 12, color: "#6e6e73" }}>{categories.find(c => c.id === p.catId)?.name}</div>
                </div>
              </div>
            ))}
            {visibleProducts.length === 0 && (
              <div style={{ gridColumn: "1/-1", textAlign: "center", padding: "60px 0", color: "#bbb" }}>
                <div style={{ fontSize: 36, marginBottom: 12 }}>🔍</div>
                <div style={{ fontSize: 15 }}>Sin resultados</div>
              </div>
            )}
          </div>
        </div>

        {/* FOOTER */}
        <div style={{ background: "#1d1d1f", color: "#fff", textAlign: "center", padding: "40px 32px", marginTop: 60 }}>
          <div style={{ display: "flex", justifyContent: "center", marginBottom: 14 }}>
            <LogoJ10 size={38} color="#fff" />
          </div>
          <div style={{ fontSize: 12, color: "rgba(255,255,255,0.4)", letterSpacing: 1 }}>Distribuciones J10 — Todos los derechos reservados</div>
        </div>

        <a href={"https://wa.me/" + whatsapp} target="_blank" rel="noreferrer"
          style={{ position: "fixed", bottom: 28, right: 28, background: "#25d366", borderRadius: "50%", width: 58, height: 58, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 26, zIndex: 150, boxShadow: "0 4px 20px rgba(37,211,102,0.45)", textDecoration: "none" }}>💬</a>
      </>}

      {/* ADMIN */}
      {view === "admin" && (
        <div style={{ maxWidth: 600, margin: "0 auto", padding: "28px 20px" }}>

          {/* Logo */}
          <AdminSection label="Logo de la empresa">
            <div style={{ display: "flex", alignItems: "center", gap: 16 }}>
              <div style={{ width: 64, height: 64, borderRadius: 12, background: "#f5f5f7", border: "1px solid #e5e5ea", display: "flex", alignItems: "center", justifyContent: "center", overflow: "hidden", flexShrink: 0 }}>
                {logoImg ? <img src={logoImg} alt="logo" style={{ width: "100%", height: "100%", objectFit: "contain" }} /> : <LogoJ10 size={40} />}
              </div>
              <div style={{ flex: 1 }}>
                <div style={{ fontSize: 14, fontWeight: 600, marginBottom: 2 }}>Logo actual</div>
                <div style={{ fontSize: 12, color: "#6e6e73" }}>PNG, JPG o SVG</div>
              </div>
              <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                <button onClick={() => logoRef.current.click()} style={{ ...secBtn, padding: "8px 16px", fontSize: 13, borderRadius: 10 }}>Subir</button>
                {logoImg && <button onClick={() => updLogo(null)} style={{ ...ghostBtn, padding: "7px 16px", fontSize: 13, borderRadius: 10, color: "#ff3b30" }}>Quitar</button>}
              </div>
              <input ref={logoRef} type="file" accept="image/*" style={{ display: "none" }} onChange={async e => { const f = e.target.files[0]; if (f) updLogo(await fileToBase64(f)); }} />
            </div>
          </AdminSection>

          {/* Banner */}
          <AdminSection label="Banner principal">
            <div style={{ borderRadius: 12, overflow: "hidden", position: "relative", height: 140, background: "#1d1d1f", marginBottom: 14 }}>
              {bannerImg && <img src={bannerImg} alt="banner" style={{ width: "100%", height: "100%", objectFit: "cover", opacity: 0.6 }} />}
              <div style={{ position: "absolute", inset: 0, display: "flex", alignItems: "center", justifyContent: "center" }}>
                <div style={{ fontSize: 13, fontWeight: 600, color: "#fff", letterSpacing: 0.5 }}>Vista previa del banner</div>
              </div>
            </div>
            {!editingBanner
              ? <button onClick={() => setEditingBanner(true)} style={{ ...secBtn, width: "100%", padding: 12, borderRadius: 12, fontSize: 14 }}>🖼️ Cambiar imagen del banner</button>
              : <div>
                  <ImagePicker value={bannerImg} onChange={v => { updBanner(v); setEditingBanner(false); }} />
                  <button onClick={() => setEditingBanner(false)} style={{ ...ghostBtn, width: "100%", padding: 11, borderRadius: 12, marginTop: 8 }}>Cancelar</button>
                </div>}
          </AdminSection>

          {/* Seguridad */}
          <AdminSection label="Seguridad">
            {!changingPw
              ? <div style={{ display: "flex", alignItems: "center" }}>
                  <div style={{ flex: 1, fontSize: 15 }}>🔐 Contraseña de acceso</div>
                  <button style={{ ...ghostBtn, padding: "8px 16px", fontSize: 13, borderRadius: 8 }} onClick={() => setChangingPw(true)}>Cambiar</button>
                </div>
              : <>
                  <div style={{ fontSize: 13, color: "#6e6e73", marginBottom: 6 }}>Nueva contraseña (mín. 6 caracteres)</div>
                  <input type="password" style={inp} placeholder="Nueva contraseña" value={newPw} onChange={e => { setNewPw(e.target.value); setPwError(""); }} />
                  <div style={{ fontSize: 13, color: "#6e6e73", marginBottom: 6 }}>Confirmar contraseña</div>
                  <input type="password" style={inp} placeholder="Repetir contraseña" value={confirmPw} onChange={e => { setConfirmPw(e.target.value); setPwError(""); }} />
                  {pwError && <div style={{ color: "#ff3b30", fontSize: 13, marginBottom: 10 }}>{pwError}</div>}
                  <div style={{ display: "flex", gap: 8 }}>
                    <button style={{ ...secBtn, flex: 1 }} onClick={savePassword}>Guardar</button>
                    <button style={{ ...ghostBtn, flex: 1 }} onClick={() => { setChangingPw(false); setNewPw(""); setConfirmPw(""); setPwError(""); }}>Cancelar</button>
                  </div>
                </>}
          </AdminSection>

          {/* WhatsApp */}
          <AdminSection label="WhatsApp de contacto">
            {editingWa
              ? <div style={{ display: "flex", gap: 8 }}>
                  <input style={{ ...inp, marginBottom: 0, flex: 1 }} value={waInput} onChange={e => setWaInput(e.target.value)} placeholder="ej: 573001234567" />
                  <button style={{ ...secBtn }} onClick={() => { updWa(waInput); setEditingWa(false); }}>Guardar</button>
                </div>
              : <div style={{ display: "flex", alignItems: "center" }}>
                  <div style={{ flex: 1, fontSize: 15 }}>💬 +{whatsapp}</div>
                  <button style={{ ...ghostBtn, padding: "8px 16px", fontSize: 13, borderRadius: 8 }} onClick={() => { setWaInput(whatsapp); setEditingWa(true); }}>Editar</button>
                </div>}
          </AdminSection>

          {/* Categorías */}
          <AdminSection label="Categorías">
            {categories.map((c, i) => (
              <div key={c.id} style={{ display: "flex", alignItems: "center", paddingBottom: 12, marginBottom: 12, borderBottom: i < categories.length - 1 ? "1px solid #f2f2f7" : "none" }}>
                <div style={{ flex: 1, fontSize: 15 }}>{c.icon} {c.name}</div>
                <button onClick={() => deleteCat(c.id)} style={{ background: "#fff0f0", border: "none", color: "#ff3b30", borderRadius: 8, padding: "6px 12px", cursor: "pointer", fontSize: 13, fontWeight: 500 }}>Eliminar</button>
              </div>
            ))}
            {showIconPicker && (
              <div style={{ display: "flex", flexWrap: "wrap", gap: 6, background: "#f5f5f7", borderRadius: 12, padding: 12, marginBottom: 10 }}>
                {ICONS.map(ic => (
                  <button key={ic} onClick={() => { setNewCatIcon(ic); setShowIconPicker(false); }}
                    style={{ fontSize: 20, background: newCatIcon === ic ? "#1d1d1f" : "transparent", border: "none", borderRadius: 6, padding: "4px 6px", cursor: "pointer" }}>{ic}</button>
                ))}
              </div>
            )}
            <div style={{ display: "flex", gap: 8 }}>
              <button onClick={() => setShowIconPicker(v => !v)} style={{ fontSize: 20, background: "#f5f5f7", border: "1px solid #d1d1d6", borderRadius: 10, padding: "0 12px", cursor: "pointer", height: 44, flexShrink: 0 }}>{newCatIcon}</button>
              <input style={{ ...inp, marginBottom: 0, flex: 1 }} placeholder="Nueva categoría..." value={newCatName} onChange={e => setNewCatName(e.target.value)} onKeyDown={e => { if (e.key === "Enter") addCategory(); }} />
              <button style={{ ...secBtn, height: 44, padding: "0 16px" }} onClick={addCategory}>+ Agregar</button>
            </div>
          </AdminSection>

          {/* Agregar producto */}
          <AdminSection label="Agregar producto">
            <div style={{ fontSize: 13, color: "#6e6e73", marginBottom: 6 }}>Nombre del producto</div>
            <input style={inp} placeholder="ej: Silla Ergonómica" value={uploadName} onChange={e => setUploadName(e.target.value)} />
            <div style={{ fontSize: 13, color: "#6e6e73", marginBottom: 6 }}>Categoría</div>
            <select style={{ ...inp, appearance: "none" }} value={uploadCat} onChange={e => setUploadCat(e.target.value)}>
              <option value="">Seleccionar categoría...</option>
              {categories.map(c => <option key={c.id} value={c.id}>{c.name}</option>)}
            </select>
            <div style={{ fontSize: 13, color: "#6e6e73", marginBottom: 6 }}>Foto del producto</div>
            <ImagePicker value={uploadImg} onChange={setUploadImg} />
            <button onClick={addProduct} style={{ ...secBtn, width: "100%", padding: 13, borderRadius: 12, marginTop: 8, fontSize: 15, opacity: (!uploadName.trim() || !uploadImg || !uploadCat) ? 0.4 : 1 }}>
              Agregar al catálogo
            </button>
          </AdminSection>

          {/* Gestionar productos */}
          <div style={{ fontSize: 11, fontWeight: 700, letterSpacing: 1, textTransform: "uppercase", color: "#6e6e73", marginBottom: 10, borderBottom: "1px solid #e5e5ea", paddingBottom: 8 }}>
            Productos ({products.length})
          </div>
          <div style={{ display: "flex", gap: 6, marginBottom: 14, flexWrap: "wrap" }}>
            {[{ id: null, name: "Todos" }, ...categories].map(c => {
              const active = c.id === null ? !activeCat : activeCat === c.id;
              return (
                <button key={c.id === null ? "all" : c.id} onClick={() => setActiveCat(c.id)}
                  style={{ padding: "7px 16px", borderRadius: 20, border: "1px solid " + (active ? "#1d1d1f" : "#d1d1d6"), background: active ? "#1d1d1f" : "transparent", color: active ? "#fff" : "#555", cursor: "pointer", fontSize: 13, fontWeight: 500 }}>
                  {c.name}
                </button>
              );
            })}
          </div>
          <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
            {(activeCat ? products.filter(p => p.catId === activeCat) : products).map(p => (
              <div key={p.id} style={{ display: "flex", alignItems: "center", gap: 12, background: "#fff", borderRadius: 14, padding: 12, border: "1px solid #e5e5ea" }}>
                <img src={p.img} alt={p.name} style={{ width: 52, height: 52, borderRadius: 10, objectFit: "cover", flexShrink: 0 }} />
                <div style={{ flex: 1, minWidth: 0 }}>
                  <div style={{ fontWeight: 600, fontSize: 14, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{p.name}</div>
                  <div style={{ fontSize: 12, color: "#6e6e73", marginTop: 2 }}>{categories.find(c => c.id === p.catId)?.name}</div>
                </div>
                <button onClick={() => toggleProduct(p.id)} style={{ padding: "6px 12px", borderRadius: 8, border: "none", background: p.enabled ? "#e8faf0" : "#fff2f2", color: p.enabled ? "#34c759" : "#ff3b30", fontWeight: 600, cursor: "pointer", fontSize: 12, whiteSpace: "nowrap", flexShrink: 0 }}>
                  {p.enabled ? "✓ Activo" : "✗ Oculto"}
                </button>
                <button onClick={() => setEditingProduct({ ...p })} style={{ background: "#f0f5ff", border: "none", color: "#007aff", borderRadius: 8, padding: "7px 10px", cursor: "pointer", fontSize: 15, flexShrink: 0 }}>✏️</button>
                <button onClick={() => deleteProduct(p.id)} style={{ background: "#fff2f2", border: "none", color: "#ff3b30", borderRadius: 8, padding: "7px 10px", cursor: "pointer", fontSize: 15, flexShrink: 0 }}>🗑</button>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* EDIT MODAL */}
      {editingProduct && (
        <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.45)", zIndex: 200, display: "flex", alignItems: "center", justifyContent: "center" }} onClick={() => setEditingProduct(null)}>
          <div style={{ background: "#fff", borderRadius: 20, padding: 28, width: 390, maxWidth: "94vw", maxHeight: "90vh", overflowY: "auto", boxShadow: "0 20px 60px rgba(0,0,0,0.2)" }} onClick={e => e.stopPropagation()}>
            <div style={{ fontSize: 18, fontWeight: 700, marginBottom: 20 }}>Editar producto</div>
            <div style={{ fontSize: 13, color: "#6e6e73", marginBottom: 6 }}>Nombre</div>
            <input style={inp} value={editingProduct.name} onChange={e => setEditingProduct(ep => ({ ...ep, name: e.target.value }))} />
            <div style={{ fontSize: 13, color: "#6e6e73", marginBottom: 6 }}>Categoría</div>
            <select style={{ ...inp, appearance: "none" }} value={editingProduct.catId} onChange={e => setEditingProduct(ep => ({ ...ep, catId: parseInt(e.target.value) }))}>
              {categories.map(c => <option key={c.id} value={c.id}>{c.name}</option>)}
            </select>
            <div style={{ fontSize: 13, color: "#6e6e73", marginBottom: 6 }}>Foto</div>
            <ImagePicker value={editingProduct.img} onChange={img => setEditingProduct(ep => ({ ...ep, img }))} />
            <div style={{ display: "flex", gap: 10, marginTop: 12 }}>
              <button onClick={saveEdit} style={{ ...secBtn, flex: 1, padding: 12, borderRadius: 12 }}>Guardar</button>
              <button onClick={() => setEditingProduct(null)} style={{ ...ghostBtn, flex: 1, padding: 12, borderRadius: 12 }}>Cancelar</button>
            </div>
          </div>
        </div>
      )}

      {/* PRODUCT MODAL */}
      {selectedImg && (
        <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.55)", zIndex: 200, display: "flex", alignItems: "center", justifyContent: "center", padding: 20 }} onClick={() => setSelectedImg(null)}>
          <div style={{ background: "#fff", borderRadius: 24, overflow: "hidden", maxWidth: 440, width: "100%", boxShadow: "0 20px 60px rgba(0,0,0,0.3)" }} onClick={e => e.stopPropagation()}>
            <div style={{ position: "relative" }}>
              <img src={selectedImg.img} alt={selectedImg.name} style={{ width: "100%", aspectRatio: "1/1", objectFit: "cover", display: "block" }} />
              <button onClick={() => setSelectedImg(null)} style={{ position: "absolute", top: 12, right: 12, background: "#fff", border: "none", borderRadius: "50%", width: 34, height: 34, fontSize: 18, cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center", boxShadow: "0 2px 8px rgba(0,0,0,0.15)" }}>×</button>
            </div>
            <div style={{ padding: "20px 24px 26px" }}>
              <div style={{ fontSize: 12, color: "#6e6e73", marginBottom: 4 }}>{categories.find(c => c.id === selectedImg.catId)?.name}</div>
              <div style={{ fontSize: 20, fontWeight: 700, marginBottom: 18 }}>{selectedImg.name}</div>
              <a href={"https://wa.me/" + whatsapp + "?text=Hola! Me interesa: " + selectedImg.name} target="_blank" rel="noreferrer"
                style={{ display: "block", textAlign: "center", padding: 14, background: "#25d366", color: "#fff", borderRadius: 12, textDecoration: "none", fontWeight: 600, fontSize: 15 }}>
                💬 Consultar por WhatsApp
              </a>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

function AdminSection({ label, children }) {
  return (
    <div style={{ marginBottom: 24 }}>
      <div style={{ fontSize: 11, fontWeight: 700, letterSpacing: 1, textTransform: "uppercase", color: "#6e6e73", marginBottom: 10, borderBottom: "1px solid #e5e5ea", paddingBottom: 8 }}>{label}</div>
      <div style={{ background: "#fff", border: "1px solid #e5e5ea", borderRadius: 16, padding: 20 }}>{children}</div>
    </div>
  );
}
